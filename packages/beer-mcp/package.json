{
  "name": "beer-mcp",
  "version": "1.0.0",
  "description": "Model Context Protocol (MCP) server for Contoso World Beers recommendations",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx src/server.ts",
    "start:local": "tsx src/local.ts",
    "dev": "tsx watch src/server.ts",
    "dev:local": "tsx watch src/local.ts",
    "generate:beers": "npx -y genaiscript@latest run generate-beers",
    "build": "tsc",
    "clean": "rimraf lib"
  },
  "keywords": [],

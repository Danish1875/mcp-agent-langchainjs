  "license": "MIT",
  "dependencies": {
    "@azure/cosmos": "^4.3.0",
    "@azure/identity": "^4.9.1",
    "@langchain/azure-cosmosdb": "^1.2.0",
    "@langchain/openai": "^1.1.2",
    "@modelcontextprotocol/sdk": "^1.10.2",
    "dotenv": "^17.0.1",
    "express": "^5.0.1",
    "langchain": "^1.0.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22",
    "tsx": "^4",
    "typescript": "^5.8.3"
  }
}
